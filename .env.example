# --- Required ---------------------------------------------------------
# Bot API key from Echoed (starts with zbot_)
BOT_TOKEN=zbot_your_token_here

# --- Optional: Echoed endpoints --------------------------------------
ECHOED_API_URL=https://go.echoed.gg
ECHOED_SOCKET_URL=https://socket.echoed.gg

# --- Optional: command behavior --------------------------------------
COMMAND_PREFIX=!
LOG_LEVEL=info
NODE_ENV=production

# --- Optional: meme provider -----------------------------------------
MEMEAPI_BASE=https://meme-api.com

# Subreddits the random rotation pulls from (comma-separated, lowercase)
DEFAULT_SUBREDDITS=memes,dankmemes,wholesomememes,me_irl

# Subreddits users can explicitly request (comma-separated, lowercase).
# Anything outside this list is rejected with a friendly message.
ALLOWED_SUBREDDITS=memes,dankmemes,wholesomememes,me_irl,memeeconomy,prequelmemes,historymemes,programmerhumor,2meirl4meirl,terriblefacebookmemes,comedyheaven

# Show NSFW-flagged memes? Default: false (filtered out)
NSFW_ALLOWED=false

# --- Optional: tuning ------------------------------------------------
# How long a subreddit pool stays fresh before forced refetch
CACHE_TTL_MINUTES=60

# When pool drops to this many memes, kick off a background refresh
CACHE_REFRESH_AT=10

# Soft rate-limit per channel: ignore commands fired faster than this
PER_CHANNEL_COOLDOWN_MS=2000

# Track last N memes per channel so the same one doesn't appear twice in a row
SEEN_TRACKER_SIZE=20
